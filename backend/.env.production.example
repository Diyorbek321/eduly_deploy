# Eduly backend — production environment.
# Copy to backend/.env on the server. NEVER commit the real .env.

# Generate a fresh key:  openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32_OUTPUT

# PostgreSQL (use a strong password, listen only on localhost or via Docker network)
DATABASE_URL=postgresql://eduly_user:REPLACE_STRONG_PASSWORD@127.0.0.1:5432/eduly

# App
DEBUG=false
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — every frontend origin that will call the API.
# Single-domain layout (recommended for 1GB droplet): faqat asosiy domen.
# amorabox.uz ni o'zingizning domeningizga almashtiring.
CORS_ORIGINS=https://amorabox.uz,https://www.amorabox.uz

# Multi-subdomain layout uchun (agar subdomain ishlatasiz):
# CORS_ORIGINS=https://amorabox.uz,https://api.amorabox.uz,https://super.amorabox.uz,https://teacher.amorabox.uz

# Timezone
EDULY_TZ=Asia/Tashkent
